# Variables de entorno — configurar en Cloudflare Pages (Settings → Environment variables)
# Este archivo es solo de referencia; NUNCA subir un .env con valores reales.

# --- Build (Astro, prefijo PUBLIC_ = visible en el navegador) ---
# ID del contenedor de Google Tag Manager (GTM-XXXXXXX). Si está vacío, no se carga GTM.
PUBLIC_GTM_ID=
# Site key de Cloudflare Turnstile (anti-spam del formulario). Opcional.
PUBLIC_TURNSTILE_SITEKEY=

# --- Runtime (Pages Functions: functions/api/contact.ts) ---
# API key de Resend (https://resend.com)
RESEND_API_KEY=
# Casilla que recibe las consultas del formulario
CONTACT_TO=info@draanalaurabatalles.com.ar
# Remitente verificado en Resend (dominio verificado o onboarding@resend.dev para pruebas)
CONTACT_FROM=
# Secret key de Turnstile (par de PUBLIC_TURNSTILE_SITEKEY). Opcional.
TURNSTILE_SECRET=
