---
// Iconografía lineal minimalista, siguiendo la guía de estilo del cliente:
// trazo fino y uniforme (1.5), formas geométricas simples, centradas en 64×64.
// El punto decorativo bajo el icono lo aporta la tarjeta (.tarjeta__punto).
interface Props {
  nombre: string;
}
const { nombre } = Astro.props;
---

{
  nombre === 'sonrisa' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <path d="M14 24c4.5 13 11.5 19.5 18 19.5S45.5 37 50 24" />
    </svg>
  )
}
{
  nombre === 'implante' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <circle cx="32" cy="26" r="11" />
      <path d="M32 10v44" />
    </svg>
  )
}
{
  nombre === 'bracket' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <path d="M10 32h16m12 0h16" />
      <path d="M17 25v14M47 25v14" />
      <rect x="26" y="26" width="12" height="12" rx="1.5" />
    </svg>
  )
}
{
  nombre === 'arco' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <path d="M18 50V30c0-8.3 6.3-15 14-15s14 6.7 14 15v20" />
    </svg>
  )
}
{
  nombre === 'destello' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true">
      <path d="M32 10c1.8 11.6 5.6 18.2 16 20-10.4 1.8-14.2 8.4-16 20-1.8-11.6-5.6-18.2-16-20 10.4-1.8 14.2-8.4 16-20Z" />
    </svg>
  )
}
{
  nombre === 'anillos' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="25.5" cy="26" r="10" />
      <circle cx="38.5" cy="26" r="10" />
      <circle cx="32" cy="37" r="10" />
    </svg>
  )
}
{
  nombre === 'diente' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M23 12c-6 0-10 5-10 11.5 0 9.5 4.7 14.5 5.8 23 .4 3.2 1.9 4.5 3.6 4.5 3.8 0 3.4-11 9.6-11s5.8 11 9.6 11c1.7 0 3.2-1.3 3.6-4.5 1.1-8.5 5.8-13.5 5.8-23C51 17 47 12 41 12c-3.8 0-5.6 2-9 2s-5.2-2-9-2Z" />
    </svg>
  )
}
{
  nombre === 'persona' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <circle cx="32" cy="23" r="8" />
      <path d="M16 49c2.4-9.6 8.4-14 16-14s13.6 4.4 16 14" />
    </svg>
  )
}
{
  nombre === 'lupa' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <circle cx="29" cy="28" r="13" />
      <path d="M38.5 37.5 49 48" />
    </svg>
  )
}
{
  nombre === 'reloj' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <circle cx="32" cy="32" r="15" />
      <path d="M32 23.5V32l6 4.5" />
    </svg>
  )
}
{
  nombre === 'hoja' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M47 15c-17 1.5-28 11-28 27 0 2.4.4 4.6 1.1 6.6 2 .7 4.2 1.1 6.6 1.1 16 0 25.5-11 27.3-27" />
      <path d="M21 47c8.5-10.5 15-17 24-25" />
    </svg>
  )
}
{
  nombre === 'corazon' && (
    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
