---
import { Image } from 'astro:assets';
import Icono from './Icono.astro';
import { SITE } from '../data/site';
import img1 from '../assets/consultorio/hero/IMG-1.jpg';
import img2 from '../assets/consultorio/hero/IMG-2.jpg';

// encuadre propio por foto Y por breakpoint: en mobile el recorte cambia
// para que el título no pise el monitor con el isologo.
// (las fotos nuevas del cliente van a la galería, no acá)
const fotos = [
  {
    img: img1,
    alt: 'Consultorio de la Dra. Ana Laura Batalles',
    pos: '62% 42%',
    posMovil: '50% 72%',
  },
  {
    img: img2,
    alt: 'Sala de atención del consultorio',
    pos: '70% 45%',
    posMovil: '62% 68%',
  },
];
---

<section class="hero">
  <div class="hero__layout">
    <div class="hero__contenido">
      <h1>
        Estética y salud dental
        <span class="hero__acento">natural y personalizado</span>
      </h1>
      <a
        href={SITE.whatsappTurno}
        target="_blank"
        rel="noopener"
        class="boton boton--primario hero__cta"
        data-evento="whatsapp"
      >
        <Icono nombre="calendario" />
        Solicitar turno
      </a>
    </div>

    <div class="hero__media" data-carrusel>
      {
        fotos.map((foto, i) => (
          <div class:list={['hero__slide', { activo: i === 0 }]} aria-hidden={i === 0 ? 'false' : 'true'}>
            <Image
              src={foto.img}
              alt={foto.alt}
              widths={[768, 1200, 1800, 2560, 3400]}
              sizes="(max-width: 760px) 100vw, 60vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
              style={`--pos: ${foto.pos}; --pos-movil: ${foto.posMovil ?? foto.pos}`}
            />
          </div>
        ))
      }
      <div class="hero__tinte" aria-hidden="true"></div>
      <div class="hero__isla" aria-hidden="true"></div>

      <button class="hero__flecha hero__flecha--prev" aria-label="Foto anterior">‹</button>
      <button class="hero__flecha hero__flecha--next" aria-label="Foto siguiente">›</button>
      <div class="hero__puntos" role="tablist" aria-label="Fotos del consultorio">
        {fotos.map((_, i) => (
          <button
            class:list={['hero__punto', { activo: i === 0 }]}
            aria-label={`Ver foto ${i + 1}`}
            aria-current={i === 0 ? 'true' : 'false'}
            data-indice={i}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ==================================================================
     Base compartida: carrusel por opacidad, tinte cálido, controles
     ================================================================== */
  .hero {
    position: relative;
    background: var(--crema-2);
  }

  .hero__media {
    position: relative;
    overflow: hidden;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
  }

  .hero__slide.activo {
    opacity: 1;
  }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--pos, 50% 50%);
  }

  /* Tinte rosado-beige parejo sobre la foto */
  .hero__tinte {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: #cba392;
    mix-blend-mode: multiply;
    opacity: 0.22;
  }

  .hero__isla {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__cta {
    background: var(--malva-oscuro);
  }

  .hero__cta:hover {
    background: var(--malva);
  }

  .hero__acento {
    display: block;
    font-family: 'Dancing Script', cursive;
    font-weight: 600;
    font-size: 1.12em;
    margin-top: 0.1em;
  }

  .hero__flecha {
    position: absolute;
    top: 50%;
    translate: 0 -50%;
    z-index: 3;
    width: 42px;
    height: 42px;
    border: none;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.75);
    color: var(--tinta);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
    padding-bottom: 3px;
    transition: background 0.2s ease;
  }

  /* área tocable extendida (el visual queda igual) */
  .hero__flecha::after {
    content: '';
    position: absolute;
    inset: -8px;
  }

  .hero__flecha:hover {
    background: #fff;
  }

  .hero__flecha--prev {
    left: 16px;
  }

  .hero__flecha--next {
    right: 16px;
  }

  .hero__puntos {
    position: absolute;
    bottom: 12px;
    left: 50%;
    translate: -50% 0;
    z-index: 3;
    display: flex;
  }

  /* botón de 24px (objetivo táctil) con el punto visual de 8px adentro */
  .hero__punto {
    width: 24px;
    height: 24px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    display: grid;
    place-items: center;
  }

  .hero__punto::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.75);
    transition: background 0.2s ease;
  }

  .hero__punto.activo::before {
    background: var(--malva);
  }

  /* ==================================================================
     Desktop y tablet (≥761px): split editorial de la guía 3 —
     texto sobre crema a la izquierda, foto grande a la derecha
     ================================================================== */
  @media (min-width: 761px) {
    .hero {
      /* beige cálido como la zona de texto del mockup (#EBDDD0) */
      background: var(--beige);
    }

    .hero__layout {
      display: grid;
      grid-template-columns: minmax(340px, 42%) 1fr;
      align-items: stretch;
    }

    .hero__contenido {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding-block: clamp(3rem, 6vw, 5rem);
      /* el texto arranca alineado con el contenedor central */
      padding-inline-start: max(clamp(1rem, 4vw, 2rem), calc((100vw - 1120px) / 2 + 2rem));
      padding-inline-end: clamp(1.5rem, 4vw, 4rem);
    }

    .hero__contenido h1 {
      font-weight: 500;
      font-size: clamp(2rem, 3.2vw, 2.9rem);
      color: var(--tinta);
      margin-bottom: 0.8em;
    }

    .hero__acento {
      color: var(--malva-oscuro);
    }

    .hero__media {
      min-height: clamp(420px, 42vw, 620px);
    }

    /* tinte "cálido leve": los blancos del consultorio se mantienen limpios */
    .hero__tinte {
      opacity: 0.12;
    }

    .hero__isla {
      display: none;
    }

    /* fusión suave entre la zona de texto y la fotografía */
    .hero__media::after {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 90px;
      background: linear-gradient(90deg, var(--beige), rgb(239 227 215 / 0));
      pointer-events: none;
      z-index: 2;
    }
  }

  /* ==================================================================
     Mobile (≤760px): foto protagonista con el texto encima (guía 1)
     ================================================================== */
  @media (max-width: 760px) {
    .hero {
      aspect-ratio: 1.3 / 1;
      overflow: hidden;
      border-radius: 0 0 50% 50% / 0 0 44px 44px;
    }

    .hero__layout {
      height: 100%;
    }

    .hero__media {
      position: absolute;
      inset: 0;
    }

    .hero__slide img {
      object-position: var(--pos-movil, var(--pos, 50% 50%));
    }

    /* la isla cálida da fondo legible al texto */
    .hero__isla {
      background: radial-gradient(
        ellipse 300px 250px at 28% 24%,
        rgb(242 226 214 / 0.5),
        rgb(242 226 214 / 0.2) 55%,
        rgb(242 226 214 / 0) 72%
      );
    }

    .hero__contenido {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      text-align: left;
      padding: 1.1rem clamp(1rem, 4vw, 2rem) 0;
    }

    .hero__contenido h1 {
      font-size: 1.5rem;
      font-weight: 500;
      max-width: 15ch;
      color: #45382f;
      margin-bottom: 0.9em;
      text-shadow: 0 2px 16px rgb(120 86 66 / 0.22);
    }

    .hero__cta {
      font-size: 0.78rem;
      padding: 0.75em 1.3em;
    }

    .hero__flecha {
      width: 34px;
      height: 34px;
      /* debajo del CTA: con el título corto el bloque de texto quedó
         más arriba y las flechas al 58% lo pisaban */
      top: 76%;
    }

    .hero__flecha--prev {
      left: 12px;
    }

    .hero__flecha--next {
      right: 12px;
    }

    .hero__puntos {
      bottom: 6px;
    }
  }
</style>

<script>
  const carrusel = document.querySelector('[data-carrusel]');
  if (carrusel) {
    const slides = carrusel.querySelectorAll('.hero__slide');
    const puntos = carrusel.querySelectorAll('.hero__punto');
    let actual = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const mostrar = (i: number) => {
      slides[actual].classList.remove('activo');
      slides[actual].setAttribute('aria-hidden', 'true');
      puntos[actual].classList.remove('activo');
      puntos[actual].setAttribute('aria-current', 'false');
      actual = (i + slides.length) % slides.length;
      slides[actual].classList.add('activo');
      slides[actual].setAttribute('aria-hidden', 'false');
      puntos[actual].classList.add('activo');
      puntos[actual].setAttribute('aria-current', 'true');
    };

    // sin auto-avance para quien pidió menos movimiento (los controles
    // manuales siguen funcionando)
    const menosMovimiento = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const pausar = () => {
      clearInterval(timer);
      timer = undefined;
    };

    const INTERVALO = 6500;
    const reanudar = () => {
      if (timer || menosMovimiento) return;
      timer = setInterval(() => mostrar(actual + 1), INTERVALO);
    };

    // no rotar con la pestaña en segundo plano
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) pausar();
      else reanudar();
    });

    carrusel.querySelector('.hero__flecha--prev')?.addEventListener('click', () => {
      mostrar(actual - 1);
    });
    carrusel.querySelector('.hero__flecha--next')?.addEventListener('click', () => {
      mostrar(actual + 1);
    });
    puntos.forEach((p) =>
      p.addEventListener('click', () => {
        mostrar(Number((p as HTMLElement).dataset.indice));
      })
    );

    // pausa al interactuar, retoma al salir
    carrusel.addEventListener('mouseenter', pausar);
    carrusel.addEventListener('mouseleave', reanudar);
    carrusel.addEventListener('touchstart', pausar, { passive: true });
    carrusel.addEventListener('touchend', () => setTimeout(reanudar, 4000), { passive: true });

    reanudar();
  }
</script>
