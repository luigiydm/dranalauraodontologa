---
import { Image } from 'astro:assets';
import Icono from './Icono.astro';
import { SITE } from '../data/site';
import img1 from '../assets/consultorio/hero/IMG-1.jpg';
import img2 from '../assets/consultorio/hero/IMG-2.jpg';

// Encuadre propio por foto y breakpoint: en mobile el recorte cambia para
// conservar una zona útil detrás del título superpuesto.
// (las fotos nuevas del cliente van a la galería, no acá)
const fotos = [
  {
    img: img1,
    alt: 'Consultorio de la Dra. Ana Laura Batalles',
    pos: '62% 42%',
    // mobile: encuadre más alto para que el título caiga sobre la pared/ventana
    // (zona calmada) y no sobre el equipo dental (#1)
    posMovil: '48% 38%',
  },
  {
    img: img2,
    alt: 'Sala de atención del consultorio',
    pos: '70% 45%',
    posMovil: '58% 40%',
  },
];
---

<section class="hero">
  <div class="hero__layout">
    <div class="hero__contenido">
      <h1>
        Estética dental
        <span class="hero__acento">personalizada y natural</span>
      </h1>
      <p class="hero__bajada">
        Realizamos tratamientos personalizados con tecnología digital para lograr una sonrisa
        armónica y natural, cuidando la salud, la función y la estructura dental con un enfoque
        basado en la preservación de cada pieza.
      </p>
      <a
        href={SITE.whatsappTurno}
        target="_blank"
        rel="noopener"
        class="boton boton--primario hero__cta"
        data-evento="whatsapp"
      >
        <Icono nombre="calendario" />
        Solicitar turno
      </a>
    </div>

    <div class="hero__media" data-carrusel>
      {
        fotos.map((foto, i) => (
          <div class:list={['hero__slide', { activo: i === 0 }]} aria-hidden={i === 0 ? 'false' : 'true'}>
            <Image
              src={foto.img}
              alt={foto.alt}
              widths={[768, 1200, 1800, 2560, 3400]}
              sizes="(max-width: 760px) 100vw, 60vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
              style={`--pos: ${foto.pos}; --pos-movil: ${foto.posMovil ?? foto.pos}`}
            />
          </div>
        ))
      }
      <div class="hero__tinte" aria-hidden="true"></div>
      <div class="hero__isla" aria-hidden="true"></div>

      <button class="hero__flecha hero__flecha--prev" aria-label="Foto anterior">‹</button>
      <button class="hero__flecha hero__flecha--next" aria-label="Foto siguiente">›</button>
      <div class="hero__puntos" role="tablist" aria-label="Fotos del consultorio">
        {fotos.map((_, i) => (
          <button
            class:list={['hero__punto', { activo: i === 0 }]}
            aria-label={`Ver foto ${i + 1}`}
            aria-current={i === 0 ? 'true' : 'false'}
            data-indice={i}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ==================================================================
     Base compartida: carrusel por opacidad, tinte cálido, controles
     ================================================================== */
  .hero {
    position: relative;
    background: var(--crema-2);
  }

  .hero__media {
    position: relative;
    overflow: hidden;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    z-index: 1;
    transition: opacity 0.55s ease;
  }

  .hero__slide.activo {
    opacity: 1;
  }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--pos, 50% 50%);
  }

  /* Tinte rosado-beige parejo sobre la foto */
  .hero__tinte {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: #cba392;
    mix-blend-mode: multiply;
    opacity: 0.22;
  }

  .hero__isla {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__cta {
    background: var(--malva-oscuro);
  }

  .hero__cta:hover {
    background: var(--malva);
  }

  .hero__acento {
    display: block;
    font-family: 'Dancing Script', cursive;
    font-weight: 600;
    font-size: 1.12em;
    margin-top: 0.1em;
  }

  .hero__flecha {
    position: absolute;
    top: 50%;
    translate: 0 -50%;
    z-index: 3;
    width: 42px;
    height: 42px;
    border: none;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.75);
    color: var(--tinta);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
    padding-bottom: 3px;
    transition: background 0.2s ease;
  }

  /* área tocable extendida (el visual queda igual) */
  .hero__flecha::after {
    content: '';
    position: absolute;
    inset: -8px;
  }

  .hero__flecha:hover {
    background: #fff;
  }

  .hero__flecha--prev {
    left: 16px;
  }

  .hero__flecha--next {
    right: 16px;
  }

  .hero__puntos {
    position: absolute;
    bottom: 12px;
    left: 50%;
    translate: -50% 0;
    z-index: 3;
    display: flex;
  }

  /* botón de 24px (objetivo táctil) con el punto visual de 8px adentro */
  .hero__punto {
    width: 24px;
    height: 24px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    display: grid;
    place-items: center;
  }

  .hero__punto::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.75);
    transition: background 0.2s ease;
  }

  .hero__punto.activo::before {
    background: var(--malva);
  }

  /* ==================================================================
     Desktop y tablet (≥761px): split editorial de la guía 3 —
     texto sobre crema a la izquierda, foto grande a la derecha
     ================================================================== */
  @media (min-width: 761px) {
    .hero {
      /* beige cálido como la zona de texto del mockup (#EBDDD0) */
      background: var(--beige);
    }

    .hero__layout {
      display: grid;
      grid-template-columns: minmax(340px, 42%) 1fr;
      align-items: stretch;
    }

    .hero__contenido {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding-block: clamp(3rem, 6vw, 5rem);
      /* el texto arranca alineado con el contenedor central */
      padding-inline-start: max(
        clamp(1rem, 4vw, 2rem),
        calc((100vw - var(--ancho-max)) / 2 + 2rem)
      );
      padding-inline-end: clamp(1.5rem, 4vw, 4rem);
    }

    .hero__contenido h1 {
      font-weight: 500;
      font-size: clamp(1.9rem, 2.9vw, 2.6rem);
      color: var(--tinta);
      margin-bottom: 0.5em;
    }

    .hero__acento {
      color: var(--malva-oscuro);
    }

    /* subtítulo del docx v4 — solo desktop: en mobile taparía la foto */
    .hero__bajada {
      color: var(--tinta-suave);
      max-width: 42ch;
      margin-bottom: 1.6rem;
    }

    .hero__media {
      /* algo más baja para que título + bajada + CTA entren sin scroll */
      min-height: clamp(380px, 36vw, 540px);
    }

    /* tinte "cálido leve": los blancos del consultorio se mantienen limpios */
    .hero__tinte {
      opacity: 0.12;
    }

    .hero__isla {
      display: none;
    }

    /* fusión suave entre la zona de texto y la fotografía */
    .hero__media::after {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 90px;
      background: linear-gradient(90deg, var(--beige), rgb(239 227 215 / 0));
      pointer-events: none;
      z-index: 2;
    }
  }

  /* ==================================================================
     Mobile (≤760px): título claro y CTA agrupados sobre la fotografía.
     ================================================================== */
  @media (max-width: 760px) {
    .hero {
      background: var(--crema);
    }

    .hero__layout {
      display: grid;
      position: relative;
    }

    .hero__contenido,
    .hero__media {
      grid-area: 1 / 1;
    }

    /* Un único bloque de contenido sirve en ambos breakpoints. En mobile se
       superpone arriba a la izquierda, como en la referencia del cliente. */
    .hero__contenido {
      /* blanco cálido (como la referencia del cliente), un toque más limpio que el crema */
      --titulo-mobile: #fffcf7;
      position: relative;
      z-index: 4;
      align-self: start;
      justify-self: start;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      /* angosto y arrimado arriba a la izquierda, como la foto de referencia */
      width: min(68%, 15rem);
      padding: clamp(1.5rem, 6vw, 2.1rem) clamp(1.2rem, 5vw, 1.6rem) 1.2rem;
      text-align: left;
      pointer-events: none;
    }

    .hero__contenido h1 {
      font-size: clamp(1rem, 4.8vw, 1.2rem);
      font-weight: 500;
      color: var(--titulo-mobile);
      line-height: 1.1;
      margin-bottom: 0;
      text-wrap: balance;
      /* halo ajustado en las propias letras: contraste sobre fondos claros
         sin panel/velo visible detrás */
      text-shadow:
        0 0 3px rgb(20 13 8 / 0.72),
        0 1px 3px rgb(20 13 8 / 0.6),
        0 2px 6px rgb(20 13 8 / 0.45);
    }

    .hero__acento {
      color: var(--titulo-mobile);
      line-height: 1.08;
    }

    .hero__bajada {
      display: none;
    }

    /* El mismo CTA de desktop queda inmediatamente debajo del título. */
    .hero__cta {
      margin-top: 1rem;
      padding: 0.78em 1.25em;
      font-size: 0.74rem;
      white-space: nowrap;
      box-shadow: 0 8px 20px rgb(40 28 20 / 0.32);
      pointer-events: auto;
    }

    /* foto en banda con base redondeada */
    .hero__media {
      position: relative;
      z-index: 1;
      aspect-ratio: 5 / 4;
      border-radius: 0 0 44px 44px;
      overflow: hidden;
    }

    /* El recorte redondeado también en cada slide: durante el fade el slide
       entrante se promueve a su propia capa de composición y, si el radio
       viviera solo en el contenedor, "escaparía" el recorte y se vería la foto
       rectangular completa hasta terminar la transición. Con el radio en el
       propio slide, la foto entra ya recortada. */
    .hero__slide {
      border-radius: 0 0 44px 44px;
      overflow: hidden;
    }

    .hero__slide img {
      object-position: var(--pos-movil, var(--pos, 50% 50%));
    }

    /* Scrim del título: velo oscuro suave detrás del texto para asegurar
       contraste en CUALQUIER foto (incluidas las de fondo muy claro), sin
       cambiar el color del título ni reubicarlo. */
    .hero__isla {
      /* velo general suave (el contraste del título lo da el scrim del texto):
         un toque arriba y otro al pie para los puntos del carrusel */
      background:
        linear-gradient(180deg, rgb(30 21 15 / 0.16) 0%, rgb(30 21 15 / 0) 30%),
        linear-gradient(0deg, rgb(30 21 15 / 0.18) 0%, rgb(30 21 15 / 0) 22%);
    }

    /* controles del carrusel */
    .hero__flecha {
      width: 34px;
      height: 34px;
    }

    .hero__flecha--prev {
      left: 12px;
    }

    .hero__flecha--next {
      right: 12px;
    }

    /* Los puntos vuelven al pie; el contenido ocupa la zona superior. */
    .hero__puntos {
      top: auto;
      bottom: 12px;
    }
  }
</style>

<script>
  const carrusel = document.querySelector('[data-carrusel]');
  if (carrusel) {
    const slides = carrusel.querySelectorAll('.hero__slide');
    const puntos = carrusel.querySelectorAll('.hero__punto');
    let actual = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    let ocultarSaliente: ReturnType<typeof setTimeout> | undefined;
    const DURACION = 550; // igual al transition del CSS

    const mostrar = (i: number) => {
      const saliente = actual;
      const entrante = (i + slides.length) % slides.length;
      if (entrante === saliente) return;

      // Fundido limpio: la foto entrante se funde POR ENCIMA mientras la
      // saliente queda 100% opaca debajo. Así nunca se ven las dos a medias
      // (que dejaba ver el fondo gris de la veladura).
      (slides[entrante] as HTMLElement).style.zIndex = '2';
      (slides[saliente] as HTMLElement).style.zIndex = '1';
      slides[entrante].classList.add('activo');
      slides[entrante].setAttribute('aria-hidden', 'false');
      slides[saliente].setAttribute('aria-hidden', 'true');

      puntos[saliente].classList.remove('activo');
      puntos[saliente].setAttribute('aria-current', 'false');
      puntos[entrante].classList.add('activo');
      puntos[entrante].setAttribute('aria-current', 'true');

      // Terminado el fundido, oculto la saliente (queda tapada por la entrante).
      clearTimeout(ocultarSaliente);
      const previa = slides[saliente] as HTMLElement;
      ocultarSaliente = setTimeout(() => {
        previa.classList.remove('activo');
        previa.style.zIndex = '';
      }, DURACION + 60);

      actual = entrante;
    };

    // sin auto-avance para quien pidió menos movimiento (los controles
    // manuales siguen funcionando)
    const menosMovimiento = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const pausar = () => {
      clearInterval(timer);
      timer = undefined;
    };

    const INTERVALO = 6500;
    const reanudar = () => {
      if (timer || menosMovimiento) return;
      timer = setInterval(() => mostrar(actual + 1), INTERVALO);
    };

    // no rotar con la pestaña en segundo plano
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) pausar();
      else reanudar();
    });

    carrusel.querySelector('.hero__flecha--prev')?.addEventListener('click', () => {
      mostrar(actual - 1);
    });
    carrusel.querySelector('.hero__flecha--next')?.addEventListener('click', () => {
      mostrar(actual + 1);
    });
    puntos.forEach((p) =>
      p.addEventListener('click', () => {
        mostrar(Number((p as HTMLElement).dataset.indice));
      })
    );

    // pausa al interactuar, retoma al salir
    carrusel.addEventListener('mouseenter', pausar);
    carrusel.addEventListener('mouseleave', reanudar);
    carrusel.addEventListener('touchstart', pausar, { passive: true });
    carrusel.addEventListener('touchend', () => setTimeout(reanudar, 4000), { passive: true });

    reanudar();
  }
</script>
