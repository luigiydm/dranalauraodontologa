---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Icono from '../components/Icono.astro';
import SeccionContacto from '../components/SeccionContacto.astro';
import { SITE } from '../data/site';
import { tratamientos } from '../data/tratamientos';
import anaPanel from '../assets/consultorio/ana-laura-panel-retocada.png';

// "Nuestra filosofía de trabajo" — checklist del docx v4 (2026-07-15)
const filosofia = [
  'Diagnóstico preciso',
  'Planificación personalizada',
  'Preservación dental',
  'Tecnología digital',
  'Actualización permanente',
  'Atención puntual',
  'Seguimiento cercano',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  name: SITE.nombre,
  description: SITE.descripcion,
  url: SITE.url,
  telephone: '+541142576145',
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Moreno 431',
    addressLocality: 'Quilmes',
    addressRegion: 'Provincia de Buenos Aires',
    addressCountry: 'AR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lng,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Thursday'], opens: '08:00', closes: '16:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Wednesday', 'Friday'], opens: '08:00', closes: '15:00' },
  ],
  sameAs: [SITE.facebook, SITE.instagram],
};
---

<Base titulo="inicio">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  <Hero />

  <!-- Nuestra forma de trabajar (docx v4) -->
  <section class="seccion seccion--beige forma">
    <div class="contenedor">
      <h2 class="titulo-seccion">Nuestra forma de trabajar</h2>
      <div class="bajada forma__bajada">
        <p>
          Antes de indicar un tratamiento, creemos que hay una decisión mucho más importante:
          definir cuál es realmente la mejor alternativa para cada paciente.
        </p>
        <p>
          Por eso cada caso comienza con un diagnóstico preciso, una planificación personalizada
          y una evaluación cuidadosa de todas las opciones disponibles. Nuestro objetivo no es
          indicar más tratamientos, sino indicar el tratamiento correcto, priorizando siempre la
          preservación de la salud, la función y la estructura dental para obtener resultados
          más naturales, predecibles y duraderos.
        </p>
      </div>

      <div class="forma__grid">
        <div class="forma__foto">
          <!-- edición propia de Luis, sin filtro: la foto ya viene corregida -->
          <Image src={anaPanel} alt="La Dra. Ana Laura Batalles en su consultorio" width={900} />
        </div>
        <div class="forma__lista">
          <h3>Nuestra filosofía de trabajo</h3>
          <ul>
            {filosofia.map((item) => (
              <li>
                <Icono nombre="destello" />
                {item}
              </li>
            ))}
          </ul>
          <p class="forma__cierre">
            …porque entendemos que detrás de cada tratamiento hay una persona, no solamente una
            sonrisa.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dra. Ana Laura Batalles (docx v4, sin foto: la foto vive arriba) -->
  <section class="seccion doctora">
    <div class="contenedor doctora__texto">
      <h2 class="titulo-seccion">Ana Laura Batalles</h2>
      <p>
        La Dra. Ana Laura Batalles cuenta con una sólida trayectoria profesional y académica,
        combinando su práctica clínica con la actividad docente universitaria y una
        actualización permanente.
      </p>
      <p>
        Su experiencia en rehabilitaciones orales de alta complejidad, junto con su
        participación activa como asistente y disertante en cursos y congresos, respaldan una
        práctica odontológica basada en la evidencia científica, la planificación personalizada
        y la preservación de la estructura dental.
      </p>
      <p>
        La actividad docente y el contacto permanente con los avances científicos le permiten
        incorporar nuevas técnicas y herramientas de manera crítica y fundamentada,
        seleccionando en cada caso aquellas que realmente aportan un beneficio para el paciente.
      </p>
    </div>
  </section>

  <!-- Tratamientos -->
  <section class="seccion" id="tratamientos">
    <div class="contenedor">
      <h2 class="titulo-seccion">Tratamientos</h2>
      <p class="bajada">
        “Cada tratamiento es el resultado de un diagnóstico preciso y una planificación
        personalizada, priorizando siempre la salud, la función y la preservación de la
        estructura dental.”
      </p>
      <div class="grilla-tarjetas grilla-tarjetas--accesos">
        {
          tratamientos.map((t) => (
            <a class="tarjeta tarjeta--enlace" href={`/tratamientos/${t.slug}`}>
              <div class="tarjeta__icono">
                <Icono nombre={t.icono} />
              </div>
              <div class="tarjeta__punto" />
              <h3>{t.titulo}</h3>
              <p>{t.resumen}</p>
              <span class="tarjeta__mas">Conocer más</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA final (docx v4) -->
  <section class="seccion cta-final">
    <div class="contenedor">
      <h2>Agendá tu primer consulta</h2>
      <p>
        “Cada tratamiento comienza con un diagnóstico preciso y una planificación personalizada.
        Agendá tu primer consulta para evaluar tu caso y definir la mejor alternativa para vos.”
      </p>
      <a href={SITE.whatsappTurno} target="_blank" rel="noopener" class="boton boton--primario" data-evento="whatsapp">
        <Icono nombre="whatsapp" />
        Solicitar turno
      </a>
    </div>
  </section>

  <SeccionContacto />
</Base>

<style>
  /* ---- Nuestra forma de trabajar: foto + checklist de filosofía ---- */
  .forma__bajada p {
    margin-bottom: 1em;
  }

  .forma__grid {
    display: grid;
    grid-template-columns: minmax(260px, 380px) 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    /* misma anchura de contenido que el resto de las secciones (#2): antes
       quedaba tope en 60rem y se veía más angosta que Tratamientos */
    margin-inline: auto;
  }

  .forma__foto {
    position: relative;
    border-radius: var(--radio-grande, 24px);
    overflow: hidden;
    box-shadow: var(--sombra);
  }

  .forma__foto img {
    width: 100%;
    height: auto;
    display: block;
  }

  .forma__lista h3 {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .forma__lista ul {
    list-style: none;
    margin: 0 0 1.4rem;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .forma__lista li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.02rem;
  }

  .forma__lista li :global(svg) {
    width: 1.05rem;
    height: 1.05rem;
    flex: none;
    color: var(--malva-oscuro);
  }

  .forma__cierre {
    font-style: italic;
    color: var(--tinta-suave);
    margin: 0;
  }

  /* ---- Ana Laura Batalles: texto centrado, sin foto ---- */
  .doctora__texto {
    max-width: 50rem;
  }

  .doctora__texto p {
    color: var(--tinta-suave);
  }

  .grilla-tarjetas {
    display: grid;
    gap: 1.4rem;
  }

  .grilla-tarjetas--4 {
    grid-template-columns: repeat(4, 1fr);
  }

  /* 5 accesos: 3 arriba y 2 abajo, centradas respecto de las de arriba (#5).
     Grilla de 6 columnas, cada tarjeta ocupa 2; la 4.ª arranca en la col 2,
     de modo que la fila inferior queda centrada. */
  .grilla-tarjetas--accesos {
    grid-template-columns: repeat(6, 1fr);
  }

  .grilla-tarjetas--accesos > .tarjeta {
    grid-column: span 2;
  }

  .grilla-tarjetas--accesos > .tarjeta:nth-child(4) {
    grid-column: 2 / span 2;
  }

  .tarjeta--enlace {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: translate 0.2s ease, box-shadow 0.2s ease;
  }

  .tarjeta--enlace:hover {
    translate: 0 -4px;
    box-shadow: var(--sombra);
  }

  .tarjeta--enlace p {
    flex: 1;
  }

  .tarjeta__mas {
    margin-top: 1.1rem;
    font-family: var(--fuente-titulos);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--malva-oscuro);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  .cta-final .contenedor {
    text-align: center;
  }

  .cta-final h2 {
    letter-spacing: 0.06em;
  }

  .cta-final p {
    color: var(--tinta-suave);
    margin-bottom: 1.6rem;
  }

  @media (max-width: 960px) {
    .grilla-tarjetas--4 {
      grid-template-columns: repeat(2, 1fr);
    }

    /* en tablet/mobile vuelven a dos columnas normales (sin el offset de la
       fila centrada, que solo tiene sentido con las tres de arriba) */
    .grilla-tarjetas--accesos {
      grid-template-columns: repeat(2, 1fr);
    }

    .grilla-tarjetas--accesos > .tarjeta,
    .grilla-tarjetas--accesos > .tarjeta:nth-child(4) {
      grid-column: auto;
    }
  }

  @media (max-width: 700px) {
    .forma__grid {
      grid-template-columns: 1fr;
    }

    .forma__foto {
      max-width: 340px;
      margin-inline: auto;
    }
  }

  @media (max-width: 640px) {
    .grilla-tarjetas {
      gap: 0.9rem;
    }

    /* tarjetas con párrafos largos: una columna — en dos se convierten
       en túneles de texto de 3 palabras por línea */
    .grilla-tarjetas--contenido {
      grid-template-columns: 1fr;
    }

    /* accesos breves (tratamientos): dos columnas sí funcionan */
    .grilla-tarjetas--accesos {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* una sola columna únicamente en pantallas realmente angostas */
  @media (max-width: 380px) {
    .grilla-tarjetas--accesos {
      grid-template-columns: 1fr;
    }
  }
</style>
